# ==============================================================================
# Jaaykoo — STAGING (.env.jaaykoo.example)
#
# Fichier d'env DÉDIÉ à la stack apps/jaaykoo/ (≠ .env racine de JanguBi,
# ≠ .env.senafrik1, ≠ .env.guiss). Identifiants, DB et secrets PROPRES à Jaaykoo.
#
# Usage :   cp .env.jaaykoo.example .env.jaaykoo   puis remplir toutes les valeurs.
# Le .env.jaaykoo réel est git-ignoré — ne jamais le committer.
#
# Le Makefile passe `--env-file .env.jaaykoo` (interpolation compose) et le
# compose référence aussi ce fichier en `env_file` (env des conteneurs).
# ==============================================================================

# ==============================================================================
# Images Docker (DockerHub)
# ==============================================================================

DOCKERHUB_USERNAME=soszaboss
# Tag de déploiement = nom de branche (develop / stage).
# NE PAS utiliser un sha per-commit : backend, storefront et admin ont des SHAs distincts.
TAG=develop

# ==============================================================================
# Django (config.django.production — déjà forcé dans l'image)
# ==============================================================================

DJANGO_SETTINGS_MODULE=config.django.production
SECRET_KEY=change-me-use-a-long-random-secret-50-chars-min

# Hôtes autorisés : domaine public staging + domaines des fronts + service
# interne + localhost.
# `django` est indispensable : les fronts proxifient /api vers
# http://django:8000 (Host: django). Les domaines des fronts sont requis car
# Traefik route leur /ws directement vers Daphne (Host préservé) et Channels
# valide l'Origin contre ALLOWED_HOSTS.
ALLOWED_HOSTS=api-jaaykoo.kamalfils.app,jaaykoo.kamalfils.app,admin-jaaykoo.kamalfils.app,django,localhost

# --- Base de données (host=db = nom du service Docker, image pgvector pg17) ---
# DATABASE_URL doit refléter POSTGRES_* ci-dessous.
DATABASE_URL=postgres://jaaykoo_user:change-me-db-password@db:5432/jaaykoo_db
POSTGRES_DB=jaaykoo_db
POSTGRES_USER=jaaykoo_user
POSTGRES_PASSWORD=change-me-db-password

# --- Redis (cache + Channels + résultats Celery — host=redis) ---
REDIS_PASSWORD=change-me-strong-redis-password
REDIS_URL=redis://:change-me-strong-redis-password@redis:6379/1

# --- RabbitMQ (broker Celery — host=rabbitmq) ---
# /!\ Appliqués uniquement au PREMIER boot (volume vide).
RABBITMQ_DEFAULT_USER=jaaykoo
RABBITMQ_DEFAULT_PASS=change-me-strong-rabbitmq-password
CELERY_BROKER_URL=amqp://jaaykoo:change-me-strong-rabbitmq-password@rabbitmq:5672//

# --- Sécurité / reverse proxy (Traefik termine le TLS) ---
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
SECURE_CONTENT_TYPE_NOSNIFF=True

# --- CORS / CSRF ---
# Les fronts passent par leur proxy same-origin (/api) — CORS sert surtout de
# filet de sécurité pour les accès directs à l'API (mobile, Swagger).
CORS_ALLOWED_ORIGINS=https://jaaykoo.kamalfils.app,https://admin-jaaykoo.kamalfils.app
CSRF_TRUSTED_ORIGINS=https://jaaykoo.kamalfils.app,https://admin-jaaykoo.kamalfils.app,https://api-jaaykoo.kamalfils.app

# ==============================================================================
# Auth JWT via cookies httpOnly (posés par Django, relayés par le proxy des fronts)
# Le cookie est vu par le navigateur sur l'ORIGINE DU FRONT (réponse proxifiée)
# → cookie host-only : laisser AUTH_COOKIE_DOMAIN vide.
# ==============================================================================

JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=7
AUTH_COOKIE_NAME=auth_token
AUTH_REFRESH_COOKIE_NAME=auth_refresh_token
AUTH_COOKIE_SECURE=True
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_DOMAIN=

# ==============================================================================
# Webhooks paiement — OBLIGATOIRES (échec fermé : webhook rejeté si secret vide)
# En staging : utiliser les clés SANDBOX Wave / Orange Money.
# ==============================================================================

WAVE_WEBHOOK_SECRET=
ORANGE_MONEY_WEBHOOK_SECRET=

# ==============================================================================
# Stockage S3 via le MinIO du stack CORE (partagé JanguBi/Sen'Afrik/Guiss/Jaaykoo)
# Noms de variables = ceux lus par config/settings/files_and_storages.py.
# ==============================================================================

FILE_UPLOAD_STRATEGY=direct
FILE_UPLOAD_STORAGE=s3
FILE_MAX_SIZE=10485760

# Identifiants S3 — doivent correspondre à MINIO_ROOT_USER / MINIO_ROOT_PASSWORD
# du .env racine (core), ou à une access-key dédiée créée dans la console MinIO.
AWS_S3_ACCESS_KEY_ID=change-me-minio-user
AWS_S3_SECRET_ACCESS_KEY=change-me-minio-password
AWS_STORAGE_BUCKET_NAME=jaaykoo-staging

# Endpoint utilisé par boto3 (opérations S3 + signature des URLs présignées).
# IMPORTANT : mettre l'endpoint PUBLIC (https://s3.kamalfils.app) — les URLs
# présignées sont signées sur cet hôte, donc joignables par le navigateur.
AWS_S3_ENDPOINT_URL=https://s3.kamalfils.app

# Domaine public MinIO (media). Vérifier le format attendu par
# files_and_storages.py (domaine seul vs URL) avant le premier déploiement.
AWS_S3_CUSTOM_DOMAIN=s3.kamalfils.app/jaaykoo-staging
AWS_S3_URL_PROTOCOL=https:

AWS_S3_REGION_NAME=us-east-1
AWS_S3_SIGNATURE_VERSION=s3v4
# Bucket privé : ne PAS appliquer la policy public-read de l'entrypoint.
AWS_S3_PUBLIC_MEDIA_BUCKET=false
# TTL des URLs présignées (secondes).
AWS_PRESIGNED_EXPIRY=300

# ==============================================================================
# Email — envoi réel via l'API Resend (apps/emails/services.py) dès que
# RESEND_API_KEY est défini. EMAIL_SENDING_STRATEGY=local = fallback console
# (le stack staging n'a pas de mailhog).
# Même compte Resend que Guiss : clé = EMAIL_HOST_PASSWORD du .env.guiss.
# ==============================================================================

EMAIL_SENDING_STRATEGY=local
RESEND_API_KEY=change-me-resend-api-key
# Expéditeur : domaine VÉRIFIÉ dans le compte Resend obligatoire. jaaykoo.com
# n'y est pas encore vérifié → on émet depuis le domaine Guiss en staging.
EMAIL_FROM=noreply@guisstalli.com

# ==============================================================================
# Google OAuth2 (login Google) — laisser vide si non utilisé en staging
# ==============================================================================

DJANGO_GOOGLE_OAUTH2_CLIENT_ID=
DJANGO_GOOGLE_OAUTH2_CLIENT_SECRET=
DJANGO_GOOGLE_OAUTH2_PROJECT_ID=

# ==============================================================================
# Bootstrap superuser (make jaaykoo-create-superuser)
# ==============================================================================

ADMIN_EMAIL=superuser@jaaykoo.sn
ADMIN_PASSWORD=change-me-strong-password

# ==============================================================================
# Observabilité / logging
# ==============================================================================

DJANGO_DEBUG=False
LOGGING_FORMAT=json
SENTRY_DSN=
SENTRY_ENVIRONMENT=staging

# ==============================================================================
# Backup (service `backup` du compose) — dump pg périodique
# ==============================================================================

BACKUP_INTERVAL_SECONDS=86400
BACKUP_KEEP=7
