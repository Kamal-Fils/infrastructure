# Secrets — ne JAMAIS committer
.env
*.env
!.env.example

# RabbitMQ : definitions.json rendu contient le mot de passe broker EN CLAIR.
# Seul le template (definitions.tpl.json) est committé.
apps/jangubi/rabbitmq/definitions.json

# Certificats / stockage ACME Traefik
acme.json
letsencrypt/

# Dumps de sauvegarde Postgres Sen'Afrik1 (générés par le service `backup`).
# On garde le dossier (.gitkeep) mais jamais les dumps (données + volumineux).
apps/senafrik1/backups/*
!apps/senafrik1/backups/.gitkeep

# Divers
*.log
.DS_Store
