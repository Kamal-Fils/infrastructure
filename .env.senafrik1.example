# ==============================================================================
# Sen'Afrik1 Conciergerie — variables d'environnement (stack apps/senafrik1).
#
# Fichier DÉDIÉ à Sen'Afrik1 (≠ du .env racine qui sert core + JanguBi). Isolation
# totale : identifiants Postgres, SECRET_KEY et Sentry PROPRES à Sen'Afrik1 — aucun
# partage / aucune collision avec JanguBi.
#
# Usage :   cp .env.senafrik1.example .env.senafrik1   puis remplir les valeurs.
# Le compose et le Makefile ciblent ce fichier :
#   docker compose --env-file .env.senafrik1 -p senafrik1 -f apps/senafrik1/docker-compose.yml ...
#   (cf. `make senafrik1-up` / `senafrik1-deploy`)
# Le .env.senafrik1 réel est git-ignoré — ne jamais le committer.
# ==============================================================================

# ------------------------------------------------------------------------------
# Images (DockerHub) — poussées par la CI : ${DOCKERHUB_USERNAME}/senafrik1-*:${TAG}
# (dupliqués ici pour que ce fichier soit auto-suffisant pour l'interpolation compose)
# ------------------------------------------------------------------------------
DOCKERHUB_USERNAME=soszaboss
TAG=latest

# ------------------------------------------------------------------------------
# Environnement & sécurité applicative (lus par les settings FastAPI)
# ------------------------------------------------------------------------------
ENVIRONMENT=staging
# Généré par : python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-senafrik1-secret-key
# Cookies de session sécurisés (HTTPS only) hors dev — cf. CLAUDE.md §8.
SESSION_SECURE_COOKIES=true
SESSION_BACKEND=redis
CSRF_ENABLED=true

# ------------------------------------------------------------------------------
# PostgreSQL (service `db` du stack senafrik1) — base & identifiants PROPRES.
# Le backend FastAPI construit DATABASE_URL à partir de ces POSTGRES_* (host = `db`).
# ------------------------------------------------------------------------------
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=senafrik1
POSTGRES_USER=senafrik1_user
POSTGRES_PASSWORD=change-me-senafrik1-db-password

# ------------------------------------------------------------------------------
# Redis (service `redis` interne) : cache db0, rate-limit db1, broker Taskiq db3.
# PAS de RabbitMQ. Host = nom du service.
# ------------------------------------------------------------------------------
CACHE_BACKEND=redis
CACHE_REDIS_HOST=redis
RATE_LIMITER_BACKEND=redis
RATE_LIMITER_REDIS_HOST=redis
TASKIQ_ENABLED=true
TASKIQ_BROKER_TYPE=redis
TASKIQ_REDIS_HOST=redis

# ------------------------------------------------------------------------------
# CORS / URLs front (derrière Traefik en HTTPS)
# ------------------------------------------------------------------------------
CORS_ENABLED=true
# Origines front réelles (jamais '*' en staging/prod) — cf. CLAUDE.md §8.
CORS_ORIGINS=https://senafrik1.kamalfils.app
# Base des liens dans les emails (reset / invitation / undo). PAS l'en-tête Host.
FRONTEND_BASE_URL=https://senafrik1.kamalfils.app

# ------------------------------------------------------------------------------
# Email / SMTP (Resend en staging — changer SEULEMENT les credentials)
# ------------------------------------------------------------------------------
EMAIL_ENABLED=true
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=change-me-resend-api-key
SMTP_USE_TLS=true
SMTP_USE_SSL=false
# Adresse d'envoi sur un domaine vérifié Resend.
EMAIL_FROM=no-reply@senafrik1.kamalfils.app
EMAIL_FROM_NAME=Sen'Afrik1 Conciergerie

# ------------------------------------------------------------------------------
# Sentry (sentry-sdk + DSN distant ; vide => désactivé, no-op). Projet PROPRE
# à Sen'Afrik1 (≠ projet Sentry JanguBi).
# ------------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=staging

# ------------------------------------------------------------------------------
# Sauvegarde Postgres (service `backup`) — dumps périodiques.
# ------------------------------------------------------------------------------
BACKUP_INTERVAL_SECONDS=86400
BACKUP_KEEP=7
