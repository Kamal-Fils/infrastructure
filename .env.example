# ==============================================================================
# Kamal&Fils — Infrastructure (serveur 164.92.238.231 / kamalfils.app)
#
# Fichier UNIQUE partagé par les deux stacks :
#   - core/docker-compose.yml     (traefik, minio, grafana, ...)
#   - apps/jangubi/docker-compose.yml  (django, nextjs, celery, db, ...)
#
# Usage :   cp .env.example .env   puis remplir les valeurs.
# Le .env réel est git-ignoré — ne jamais le committer.
# ==============================================================================

# ==============================================================================
# CORE
# ==============================================================================
# Email du compte ACME pour Let's Encrypt (reçoit les alertes d'expiration)
TRAEFIK_ACME_EMAIL=admin@kamalfils.app

# Basic-auth du dashboard Traefik. Générer :
#   docker run --rm httpd:alpine htpasswd -nb admin 'monMotDePasse'
# IMPORTANT : DOUBLER chaque '$' de la sortie en '$$' (Compose interprète sinon
# $apr1/$xxx comme des variables et tronque le hash). Exemple de forme attendue :
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$xxxxxxxx$$xxxxxxxxxxxxxxxxxxxxx

# MinIO (compte root de l'instance S3 partagée)
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change-me-strong-password

# Grafana (mot de passe admin initial)
GRAFANA_ADMIN_PASSWORD=change-me-strong-password

# ==============================================================================
# JANGUBI — images
# ==============================================================================
DOCKERHUB_USERNAME=soszaboss
TAG=latest

# ==============================================================================
# JANGUBI — Django
# ==============================================================================
DJANGO_SETTINGS_MODULE=config.django.production
DJANGO_DEBUG=False
SECRET_KEY=change-me-use-a-long-random-secret

# Hôtes autorisés : domaine public + nom du service interne
ALLOWED_HOSTS=api-jangubi.kamalfils.app,django,localhost

# URL django-environ : doit refléter POSTGRES_* ci-dessous (host=db, port interne 5432)
DATABASE_URL=postgres://jangubi_user:change-me-db-password@db:5432/jangubi

# Redis (cache Django + Channel Layers) — host = nom du service
REDIS_URL=redis://redis:6379/1

# RabbitMQ — user broker dédié (créé via le definitions file, jamais "guest").
# Le mot de passe doit éviter " et \ (rendu dans un JSON par envsubst).
RABBITMQ_DEFAULT_USER=jangubi_broker
RABBITMQ_DEFAULT_PASS=change-me-broker-password

# Broker Celery (RabbitMQ) — host = nom du service.
# DOIT refléter RABBITMQ_DEFAULT_USER / RABBITMQ_DEFAULT_PASS ci-dessus.
CELERY_BROKER_URL=amqp://jangubi_broker:change-me-broker-password@rabbitmq:5672//

# --- Reverse proxy / sécurité (derrière Traefik en HTTPS) ---
APP_DOMAIN=https://api-jangubi.kamalfils.app
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
SECURE_CONTENT_TYPE_NOSNIFF=True

# --- CORS / CSRF : autoriser le frontend ---
CORS_ALLOW_ALL_ORIGINS=False
DJANGO_CORS_ORIGIN_WHITELIST=https://jangubi.kamalfils.app
CSRF_TRUSTED_ORIGINS=https://jangubi.kamalfils.app,https://api-jangubi.kamalfils.app
DJANGO_BASE_BACKEND_URL=https://api-jangubi.kamalfils.app
DJANGO_BASE_FRONTEND_URL=https://jangubi.kamalfils.app

# --- Logging ---
DEBUG_TOOLBAR_ENABLED=False
LOGGING_FORMAT=json

# ==============================================================================
# JANGUBI — PostgreSQL (service `db`). Garder en phase avec DATABASE_URL.
# ==============================================================================
POSTGRES_DB=jangubi
POSTGRES_USER=jangubi_user
POSTGRES_PASSWORD=change-me-db-password

# ==============================================================================
# JANGUBI — Stockage S3 via le MinIO du stack CORE (s3.kamalfils.app)
# Noms de variables = ceux lus par les settings Django (AWS_S3_*).
# ==============================================================================
FILE_UPLOAD_STRATEGY=standard
FILE_UPLOAD_STORAGE=s3
FILE_MAX_SIZE=10485760

# Doivent correspondre à MINIO_ROOT_USER / MINIO_ROOT_PASSWORD (ou à une
# access-key dédiée créée dans la console MinIO).
AWS_S3_ACCESS_KEY_ID=admin
AWS_S3_SECRET_ACCESS_KEY=change-me-strong-password
AWS_STORAGE_BUCKET_NAME=jangubi
AWS_S3_ENDPOINT_URL=https://s3.kamalfils.app
AWS_S3_REGION_NAME=us-east-1
AWS_S3_SIGNATURE_VERSION=s3v4
AWS_DEFAULT_ACL=private
AWS_PRESIGNED_EXPIRY=10
AWS_S3_CUSTOM_DOMAIN=

# ==============================================================================
# JANGUBI — Sentry (laisser vide pour désactiver)
# ==============================================================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ==============================================================================
# JANGUBI — RAG / Embeddings
# ==============================================================================
EMBEDDING_PROVIDER=local
PGVECTOR_ENABLED=True

# ==============================================================================
# JANGUBI — Compte admin initial (créé au bootstrap)
# ==============================================================================
ADMIN_EMAIL=admin@kamalfils.app
ADMIN_PASSWORD=change-me-admin-password

# ==============================================================================
# ==============================================================================
# SEN'AFRIK1 CONCIERGERIE (staging)
# ==============================================================================
# ==============================================================================
# NB images : DOCKERHUB_USERNAME et TAG sont DÉJÀ définis plus haut (section
# « JANGUBI — images ») et PARTAGÉS par les deux stacks. Le tag passé en
# argument (`make senafrik1-deploy TAG=...`) prime sur la valeur du fichier.
# Images attendues : ${DOCKERHUB_USERNAME}/senafrik1-backend|frontend:${TAG}.

# ------------------------------------------------------------------------------
# Sen'Afrik1 — Environnement & sécurité applicative (lus par les settings FastAPI)
# ------------------------------------------------------------------------------
ENVIRONMENT=staging
# Généré par : python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-use-a-long-random-secret
# Cookies de session sécurisés (HTTPS only) — true hors dev (cf. CLAUDE.md §8).
SESSION_SECURE_COOKIES=true
SESSION_BACKEND=redis
CSRF_ENABLED=true

# ------------------------------------------------------------------------------
# Sen'Afrik1 — PostgreSQL (service `db` du stack senafrik1)
# ------------------------------------------------------------------------------
# /!\ PARTAGE : POSTGRES_DB / POSTGRES_USER / POSTGRES_PASSWORD sont DÉJÀ
#     déclarés plus haut pour JanguBi et le .env est UNIQUE pour les deux stacks.
#     Les deux services `db` (jangubi_db et senafrik1_db) sont des instances
#     SÉPARÉES (volumes + réseaux distincts) mais liraient ces MÊMES identifiants.
#     -> [À CONFIRMER] : soit on accepte des credentials Postgres communs aux
#        deux apps, soit on isole Sen'Afrik1. Pas de préfixe propre possible
#        ici car le compose et les settings FastAPI lisent les clés `POSTGRES_*`
#        nues. Si isolation requise : utiliser un second .env / override compose.
#     Le backend FastAPI lit aussi POSTGRES_SERVER (host) — doit valoir `db`.
POSTGRES_SERVER=db
POSTGRES_PORT=5432
# Si tu veux des valeurs propres à Sen'Afrik1, écrase POSTGRES_DB/USER/PASSWORD
# ci-dessus AVANT le 1er `senafrik1-up` (sinon JanguBi et Sen'Afrik1 les partagent).

# ------------------------------------------------------------------------------
# Sen'Afrik1 — Redis (service `redis` interne) : cache db0, rate-limit db1,
# broker Taskiq db3. Host = nom du service. PAS de RabbitMQ.
# ------------------------------------------------------------------------------
CACHE_BACKEND=redis
CACHE_REDIS_HOST=redis
RATE_LIMITER_BACKEND=redis
RATE_LIMITER_REDIS_HOST=redis
TASKIQ_ENABLED=true
TASKIQ_BROKER_TYPE=redis
TASKIQ_REDIS_HOST=redis

# ------------------------------------------------------------------------------
# Sen'Afrik1 — CORS / URLs front (derrière Traefik en HTTPS)
# ------------------------------------------------------------------------------
CORS_ENABLED=true
# Origines front réelles (jamais '*' en staging/prod) — cf. CLAUDE.md §8.
CORS_ORIGINS=https://senafrik1.kamalfils.app
# Base des liens dans les emails (reset / invitation / undo). PAS l'en-tête Host.
FRONTEND_BASE_URL=https://senafrik1.kamalfils.app

# ------------------------------------------------------------------------------
# Sen'Afrik1 — Email / SMTP (Resend en staging — changer SEULEMENT les creds)
# ------------------------------------------------------------------------------
EMAIL_ENABLED=true
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=change-me-resend-api-key
SMTP_USE_TLS=true
SMTP_USE_SSL=false
# Adresse d'envoi sur un domaine vérifié Resend.
EMAIL_FROM=no-reply@senafrik1.kamalfils.app
EMAIL_FROM_NAME=Sen'Afrik1 Conciergerie

# ------------------------------------------------------------------------------
# Sen'Afrik1 — Sentry (sentry-sdk + DSN distant ; vide => désactivé, no-op)
# ------------------------------------------------------------------------------
# /!\ SENTRY_DSN / SENTRY_ENVIRONMENT existent déjà plus haut pour JanguBi
#     (valeur `production`). Le .env étant unique, ces clés sont PARTAGÉES :
#     mets un DSN/environnement Sen'Afrik1 ici écrase celui de JanguBi.
#     -> [À CONFIRMER] : si les deux apps doivent remonter dans des projets
#        Sentry distincts, il faut séparer les .env (le partage n'isole pas).
SENTRY_DSN=
SENTRY_ENVIRONMENT=staging

# ------------------------------------------------------------------------------
# Sen'Afrik1 — Sauvegarde Postgres (service `backup`)
# ------------------------------------------------------------------------------
# Intervalle entre deux dumps (défaut 86400s = 24h) et nb de dumps conservés.
BACKUP_INTERVAL_SECONDS=86400
BACKUP_KEEP=7
