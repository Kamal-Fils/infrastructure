# ==============================================================================
# Guiss-Talli — STAGING (.env.guiss.example)
#
# Fichier d'env DÉDIÉ à la stack apps/guiss/ (≠ .env racine de JanguBi,
# ≠ .env.senafrik1). Identifiants, DB et secrets PROPRES à Guiss.
#
# Usage :   cp .env.guiss.example .env.guiss   puis remplir toutes les valeurs.
# Le .env.guiss réel est git-ignoré — ne jamais le committer.
#
# Le Makefile passe `--env-file .env.guiss` (interpolation compose) et le
# compose référence aussi ce fichier en `env_file` (env des conteneurs).
# ==============================================================================

# ==============================================================================
# Images Docker (DockerHub)
# ==============================================================================

DOCKERHUB_USERNAME=soszaboss
# Tag de déploiement = nom de branche (develop / stage).
# NE PAS utiliser un sha per-commit : backend et frontend ont des SHAs distincts.
TAG=develop

# ==============================================================================
# Django
# ==============================================================================

DJANGO_SETTINGS_MODULE=backend.django.production
SECRET_KEY=change-me-use-a-long-random-secret-50-chars-min

# Hôtes autorisés : domaine public staging + nom du service interne + localhost
ALLOWED_HOSTS=api-guiss.kamalfils.app,django,localhost

# Nombre de proxies de confiance devant Django (Traefik = 1)
TRUSTED_PROXY_COUNT=1

# --- Base de données (host=db = nom du service Docker) ---
# DATABASE_URL doit refléter POSTGRES_* ci-dessous.
DATABASE_URL=postgres://guiss_user:change-me-db-password@db:5432/depistage_db
POSTGRES_DB=depistage_db
POSTGRES_USER=guiss_user
POSTGRES_PASSWORD=change-me-db-password

# --- Redis (cache + broker Celery — host=redis = nom du service Docker) ---
# DB 0 = cache Django, DB 1 = broker Celery
REDIS_PASSWORD=change-me-strong-redis-password
REDIS_URL=redis://:change-me-strong-redis-password@redis:6379/0
CELERY_BROKER_URL=redis://:change-me-strong-redis-password@redis:6379/1

# --- Sécurité / reverse proxy ---
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
SECURE_CONTENT_TYPE_NOSNIFF=True

# --- CORS / CSRF : autoriser le frontend Next.js staging ---
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://guiss.kamalfils.app
CSRF_TRUSTED_ORIGINS=https://guiss.kamalfils.app,https://api-guiss.kamalfils.app

# --- URLs applicatives ---
FRONTEND_URL=https://guiss.kamalfils.app
BACKEND_URL=https://api-guiss.kamalfils.app

# --- NextAuth (runtime du conteneur nextjs — server-only, jamais baké) ---
NEXTAUTH_URL=https://guiss.kamalfils.app
NEXTAUTH_SECRET=change-me-openssl-rand-base64-48

# --- Bootstrap superuser (make guiss-create-superuser) ---
ADMIN_EMAIL=superuser@guiss.sn
ADMIN_PASSWORD=change-me-strong-password

# --- Logging ---
DEBUG=False
DEBUG_TOOLBAR_ENABLED=False
LOGGING_FORMAT=json
# Conteneur non-root : pas de handlers fichier (stdout only, docker logs collecte)
LOG_TO_FILE=False

# ==============================================================================
# Stockage S3 via le MinIO du stack CORE (partagé JanguBi/Sen'Afrik/Guiss)
# Noms de variables = ceux lus par les settings Django (AWS_S3_*).
# ==============================================================================

FILE_UPLOAD_STRATEGY=standard
FILE_UPLOAD_STORAGE=s3
FILE_MAX_SIZE=10485760

# Identifiants S3 — doivent correspondre à MINIO_ROOT_USER / MINIO_ROOT_PASSWORD
# du .env racine (core), ou à une access-key dédiée créée dans la console MinIO.
AWS_S3_ACCESS_KEY_ID=change-me-minio-user
AWS_S3_SECRET_ACCESS_KEY=change-me-minio-password
AWS_STORAGE_BUCKET_NAME=guiss-staging

# URL interne Docker : pour les appels depuis django/celery vers le conteneur
# minio du core (joignable via le réseau traefik-public).
AWS_S3_ENDPOINT_URL=http://minio:9000

# Domaine public pour les presigned URLs renvoyées aux clients.
AWS_S3_CUSTOM_DOMAIN=

AWS_S3_REGION_NAME=us-east-1
AWS_S3_SIGNATURE_VERSION=s3v4
AWS_DEFAULT_ACL=private
AWS_PRESIGNED_EXPIRY=10

# ==============================================================================
# FHIR (HAPI FHIR R4 — service `hapi`, interne uniquement)
# Django utilise FHIR_SERVER_BASE_URL pour les appels internes.
# ==============================================================================

# URL interne Docker (host=hapi = nom du service Docker)
FHIR_SERVER_BASE_URL=http://hapi:8080/fhir
FHIR_ENABLED=True

# Base PostgreSQL dédiée HAPI (service `hapi-db`, interne, PHI)
HAPI_DB_NAME=hapi
HAPI_DB_USER=hapi
HAPI_DB_PASSWORD=change-me-hapi-db-password

# ==============================================================================
# WhatsApp / Twilio (notifications rendez-vous) — SANDBOX en staging
# ==============================================================================

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# WhatsApp Business API (alternative directe, si non Twilio)
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ==============================================================================
# IA / Gemini (génération de rapports cliniques) — clé de dev/staging dédiée
# ==============================================================================

GEMINI_API_KEY=

# ==============================================================================
# Sentry (laisser vide pour désactiver)
# ==============================================================================

SENTRY_DSN=
SENTRY_ENVIRONMENT=staging

# ==============================================================================
# Backup (service `backup` du compose) — dump pg périodique
# ==============================================================================

BACKUP_INTERVAL_SECONDS=86400
BACKUP_KEEP=7
